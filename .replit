modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/vibe-app run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd apps/api-server && pnpm run build && PORT=3000 node --enable-source-maps ./dist/index.mjs"
waitForPort = 3000

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 23636
externalPort = 3001

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=8080 node --enable-source-maps apps/api-server/dist/index.mjs & PORT=5000 BASE_PATH=/ pnpm --filter @workspace/vibe-app run build && node -e \"const http=require('http'),fs=require('fs'),path=require('path');const dist='apps/vibe-app/dist/public';const s=http.createServer((req,res)=>{let f=path.join(dist,req.url==='/'?'/index.html':req.url);if(!fs.existsSync(f))f=path.join(dist,'index.html');const ext=path.extname(f);const mt={'html':'text/html','js':'application/javascript','css':'text/css','json':'application/json','ico':'image/x-icon','png':'image/png','svg':'image/svg+xml','woff2':'font/woff2'};res.setHeader('Content-Type',mt[ext.slice(1)]||'text/plain');fs.createReadStream(f).pipe(res)});s.listen(5000,'0.0.0.0')\""]
build = ["bash", "-c", "CI=true pnpm install && cd packages/db && pnpm exec drizzle-kit push && cd ../api-spec && pnpm exec orval && cd ../../apps/api-server && pnpm run build"]

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "8080"
LOG_LEVEL = "info"
JWT_SECRET = "bd718cc72176612b96041ef8cc933ee1bbb0d8cafb8b7242e1c3a122f234bff4b8e35fb5c6f65cafdee9577efd34c29ea4cf771339e508203bc66d878bb8e732"
