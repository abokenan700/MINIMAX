modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 BASE_PATH=/ pnpm --filter @workspace/vibe-app run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=8080 pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8080
externalPort = 80

[deployment]
deploymentTarget = "autoscale"
run = ["bash", "-c", "PORT=8080 node --enable-source-maps apps/api-server/dist/index.mjs & PORT=5000 BASE_PATH=/ pnpm --filter @workspace/vibe-app run build && node -e \"const http=require('http'),fs=require('fs'),path=require('path');const dist='apps/vibe-app/dist/public';const s=http.createServer((req,res)=>{let f=path.join(dist,req.url==='/'?'/index.html':req.url);if(!fs.existsSync(f))f=path.join(dist,'index.html');const ext=path.extname(f);const mt={'html':'text/html','js':'application/javascript','css':'text/css','json':'application/json','ico':'image/x-icon','png':'image/png','svg':'image/svg+xml','woff2':'font/woff2'};res.setHeader('Content-Type',mt[ext.slice(1)]||'text/plain');fs.createReadStream(f).pipe(res)});s.listen(5000,'0.0.0.0')\""]
build = ["bash", "-c", "CI=true pnpm install && cd packages/db && pnpm exec drizzle-kit push && cd ../api-spec && pnpm exec orval && cd ../../apps/api-server && pnpm run build"]

[userenv]

[userenv.shared]
NODE_ENV = "development"
PORT = "8080"
LOG_LEVEL = "info"
JWT_SECRET = "e817102e844321feb509b192ed5b962d6c19cf8865ec96ab3b72091d725b5c1769fc5281b5493ca55bf1fcd97d01649d8a1b642e4e9378586a46bd829f0c79f6"
